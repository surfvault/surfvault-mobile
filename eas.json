{
  "cli": {
    "version": ">= 15.0.0"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "API_BASE_URL": "https://dev-api.surf-vault.com",
        "ENVIRONMENT": "dev"
      }
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "API_BASE_URL": "https://beta-api.surf-vault.com",
        "ENVIRONMENT": "beta"
      }
    },
    "production": {
      "env": {
        "API_BASE_URL": "https://api.surf-vault.com",
        "ENVIRONMENT": "prod"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
